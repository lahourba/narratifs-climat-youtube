# Copie ce fichier en .env et renseigne tes clés.
#   cp .env.example .env
# Le .env est chargé automatiquement par tous les scripts (via common.py)
# et n'est PAS versionné (.gitignore).

# Clé YouTube Data API v3 (utilisée par collect.py)
YOUTUBE_API_KEY=

# Clé API Anthropic (utilisée par classify.py si LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# --- Choix du fournisseur LLM pour la classification (défaut : anthropic) ---
# LLM_PROVIDER=anthropic|ollama|openai|gemini
# LLM_PROVIDER=openai
#   OPENAI_API_KEY=sk-...
#   OPENAI_MODEL=gpt-4o-mini            # défaut
# LLM_PROVIDER=gemini
#   GEMINI_API_KEY=...                  # console : aistudio.google.com/apikey
#   GEMINI_MODEL=gemini-2.0-flash       # défaut
# LLM_PROVIDER=ollama                   # local, gratuit mais lent sur laptop
#   OLLAMA_MODEL=mistral:7b-instruct
# Taille du transcript envoyé au modèle (défaut 1500 mots) :
# TRANSCRIPT_WORDS=1500

# --- Optionnel : proxy pour youtube-transcript-api (contourne les blocages d'IP) ---
# Proxy HTTP(S) générique, ex : http://user:pass@host:port
# YT_HTTP_PROXY=
# YT_HTTPS_PROXY=
# Ou identifiants Webshare (proxies résidentiels recommandés pour gros corpus) :
# WEBSHARE_PROXY_USERNAME=
# WEBSHARE_PROXY_PASSWORD=
